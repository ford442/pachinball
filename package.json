{
  "name": "pachinball",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:wasm",
    "build_colab": "tsc -b && vite build && npm run build:wasm_colab",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:wasm_colab": "bash scripts/build-wasm-colab.sh",
    "build:wasm:debug": "bash scripts/build-wasm.sh --debug",
    "build:wasm:assert": "bash scripts/build-wasm.sh --assert",
    "bench:wasm-flags": "bash scripts/build-wasm.sh --bench-matrix && node scripts/bench-wasm-flags.mjs",
    "test:native": "cmake -S native -B native/build-native && cmake --build native/build-native && ctest --test-dir native/build-native --output-on-failure",
    "test:wasm-parity": "node scripts/run-wasm-parity.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "models:cabinet-placeholders": "node scripts/generate-cabinet-placeholders.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@babylonjs/core": "^7.45.0",
    "@babylonjs/loaders": "^7.54.3",
    "@dimforge/rapier3d-compat": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "puppeteer": "^25.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.1"
  }
}
